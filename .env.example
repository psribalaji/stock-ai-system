# ─────────────────────────────────────────────────────────────
# .env.example — Copy this to .env and fill in your API keys.
# NEVER commit your actual .env file to git.
# ─────────────────────────────────────────────────────────────

# Alpaca Markets — https://app.alpaca.markets/paper-trading/overview
# Use PAPER keys for now (they look different from live keys)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Polygon.io — https://polygon.io/dashboard/api-keys
POLYGON_API_KEY=your_polygon_api_key_here

# Finnhub — https://finnhub.io/dashboard
FINNHUB_API_KEY=your_finnhub_api_key_here

# Anthropic — https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Reddit API (optional - for social sentiment scanning)
# Get credentials at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=StockAI/1.0
